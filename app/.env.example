# Database connection (PostgreSQL via Neon or direct)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT Secret (minimum 32 characters for production)
JWT_SECRET="generate-a-secure-random-string-at-least-32-chars"

# Environment
NODE_ENV="development"

# Payment (Razorpay)
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# App URL (for CORS, sitemap, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
