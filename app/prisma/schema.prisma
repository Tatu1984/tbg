generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      String   @default("cashier") // owner, manager, cashier, inventory_staff
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices          Invoice[]
  stockTransactions StockTransaction[]
  cashSales         CashSale[]

  @@index([role])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model Setting {
  id        String   @id
  data      Json
  updatedAt DateTime @updatedAt
}

model Product {
  id              String   @id @default(cuid())
  sku             String   @unique
  hsn             String?
  name            String
  categoryId      String
  brand           String?
  size            String?
  color           String?
  costPrice       Decimal  @db.Decimal(12, 2)
  sellingPrice    Decimal  @db.Decimal(12, 2)
  mrp             Decimal  @db.Decimal(12, 2)
  gstPercentage   Decimal  @default(18) @db.Decimal(5, 2)
  stock           Int      @default(0)
  reorderLevel    Int      @default(5)
  availableOnline Boolean  @default(false)
  imageUrl        String?
  description     String?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category          Category           @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  invoiceItems      InvoiceItem[]
  stockTransactions StockTransaction[]
  cashSales         CashSale[]
  cartItems         CartItem[]
  orderItems        OrderItem[]
  purchaseItems     PurchaseItem[]

  @@index([categoryId])
  @@index([active, stock])
  @@index([name])
}

model Supplier {
  id           String   @id @default(cuid())
  name         String
  contactPhone String?
  address      String?
  gstNumber    String?
  paymentTerms String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  purchases Purchase[]
}

model Invoice {
  id            String   @id @default(cuid())
  invoiceNumber String   @unique
  userId        String
  customerName  String?
  customerPhone String?
  subtotal      Decimal  @db.Decimal(12, 2)
  gstAmount     Decimal  @db.Decimal(12, 2)
  discount      Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal  @db.Decimal(12, 2)
  paymentMethod String
  paymentDetail String?
  status        String   @default("completed")
  createdAt     DateTime @default(now())

  user  User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  items InvoiceItem[]

  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@index([customerPhone])
}

model InvoiceItem {
  id         String  @id @default(cuid())
  invoiceId  String
  productId  String
  quantity   Int
  unitPrice  Decimal @db.Decimal(12, 2)
  gstAmount  Decimal @db.Decimal(12, 2)
  discount   Decimal @default(0) @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([productId])
}

model StockTransaction {
  id        String   @id @default(cuid())
  productId String
  userId    String
  type      String
  quantity  Int
  notes     String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([userId])
  @@index([createdAt])
}

model CashSale {
  id        String   @id @default(cuid())
  productId String
  userId    String
  quantity  Int
  notes     String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([userId])
}

model Purchase {
  id         String   @id @default(cuid())
  supplierId String
  totalCost  Decimal  @db.Decimal(12, 2)
  notes      String?
  createdAt  DateTime @default(now())

  supplier Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items    PurchaseItem[]

  @@index([supplierId])
}

model PurchaseItem {
  id         String  @id @default(cuid())
  purchaseId String
  productId  String
  quantity   Int
  unitCost   Decimal @db.Decimal(12, 2)
  totalCost  Decimal @db.Decimal(12, 2)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([productId])
}

model Customer {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  addresses Address[]
  cart      CartItem[]
  orders    Order[]
}

model Address {
  id         String  @id @default(cuid())
  customerId String
  label      String  @default("Home")
  line1      String
  line2      String?
  city       String
  state      String
  pincode    String
  isDefault  Boolean @default(false)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  orders   Order[]

  @@index([customerId])
}

model CartItem {
  id         String @id @default(cuid())
  customerId String
  productId  String
  quantity   Int

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([customerId, productId])
}

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  customerId      String
  addressId       String
  subtotal        Decimal  @db.Decimal(12, 2)
  gstAmount       Decimal  @db.Decimal(12, 2)
  shippingCharge  Decimal  @default(0) @db.Decimal(12, 2)
  totalAmount     Decimal  @db.Decimal(12, 2)
  paymentMethod   String
  paymentId       String?
  status          String   @default("confirmed")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customer Customer    @relation(fields: [customerId], references: [id], onDelete: Restrict)
  address  Address     @relation(fields: [addressId], references: [id], onDelete: Restrict)
  items    OrderItem[]

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String
  quantity   Int
  unitPrice  Decimal @db.Decimal(12, 2)
  totalPrice Decimal @db.Decimal(12, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}
